<UserControl
    x:Class="SynQPanel.Views.Components.FlipProperties"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SynQPanel.Models"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="FlipTimeUnitValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:FlipTimeUnit"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="FlipStyleValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:FlipStyle"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <!-- MAIN LAYOUT: 2 ROWS -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Top Section -->
            <RowDefinition Height="Auto" />
            <!-- Advanced Expander (Full Width) -->
        </Grid.RowDefinitions>

        <!-- TOP SECTION (Split Left/Right) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="160" />
                <!-- Fixed Preview Width -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: CONTROLS -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,15,0">

                <TextBlock Text="Flip Display" FontWeight="SemiBold" Margin="0,0,0,15" />

                <!-- ROW 1: DIMENSIONS + FOLDER -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <!-- W -->
                        <ColumnDefinition Width="120" />
                        <!-- H -->
                        <ColumnDefinition Width="*" />
                        <!-- Path Stretches -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Button Auto -->
                    </Grid.ColumnDefinitions>

                    <!-- W -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <ui:NumberBox Maximum="2000" Minimum="1" Text="{Binding Width}" Value="{Binding Width}" PlaceholderText="W" />
                        <TextBlock Text="Width" FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                    </StackPanel>

                    <!-- H -->
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <ui:NumberBox Maximum="2000" Minimum="1" Text="{Binding Height}" Value="{Binding Height}" PlaceholderText="H" />
                        <TextBlock Text="Height" FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                    </StackPanel>

                    <!-- Path -->
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBox IsReadOnly="True" Text="{Binding CalculatedImageFolder, Mode=OneWay}" ToolTip="{Binding CalculatedImageFolder}" VerticalContentAlignment="Center" FontSize="11" Height="32"/>
                        <TextBlock Text="Folder Path" FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                    </StackPanel>

                    <!-- Browse Button -->
                    <StackPanel Grid.Column="3">
                        <Button Click="ButtonSelectFlipFolder_Click" ToolTip="Select Folder" Height="32" Width="40" Padding="0">
                            <TextBlock Text="..." FontWeight="Bold" FontSize="14" Margin="0,-4,0,0"/>
                        </Button>
                        <TextBlock Text="Browse" FontSize="11" Foreground="Gray" Margin="2,2,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ROW 2: STYLE & TIMING -->
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Flip Style -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <ComboBox x:Name="FlipStyleComboBox" ItemsSource="{Binding Source={StaticResource FlipStyleValues}}" SelectedItem="{Binding FlipStyle, Mode=TwoWay}" SelectionChanged="FlipStyleComboBox_SelectionChanged" />
                        <TextBlock Text="Style" FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                    </StackPanel>

                    <!-- Spacing -->
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <ui:NumberBox x:Name="DigitSpacingNumberBox" Maximum="50" Minimum="0" Text="{Binding DigitSpacing}" Value="{Binding DigitSpacing}" />
                        <TextBlock x:Name="DigitSpacingLabel" Text="Spacing" FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                    </StackPanel>

                    <!-- Time Unit -->
                    <StackPanel Grid.Column="2" Margin="0,0,0,0">
                        <ComboBox ItemsSource="{Binding Source={StaticResource FlipTimeUnitValues}}" SelectedItem="{Binding TimeUnit, Mode=TwoWay}" />
                        <TextBlock Text="Unit" FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ROW 3: STATUS -->
                <TextBlock x:Name="ImportStatusText" FontSize="12" Margin="2,10,0,10" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Text="Ready" />

                <!-- ROW 4: ADVANCED EFFECTS -->
                <!-- ROW 4: ADVANCED EFFECTS (Direct Layout, No Expander) -->
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 1. Duration (Left) -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,10">
                        <Grid>
                            <TextBlock Text="Duration" FontSize="11" Foreground="Gray" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding AnimationDuration, StringFormat=N1}" FontSize="11" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Slider Minimum="0.1" Maximum="1.5" SmallChange="0.1" LargeChange="0.1" TickFrequency="0.1" IsSnapToTickEnabled="True" 
                 Value="{Binding AnimationDuration}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- 2. Shadows (Right) -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,10">
                        <Grid>
                            <TextBlock Text="Shadows" FontSize="11" Foreground="Gray" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding ShadowIntensity, StringFormat=P0}" FontSize="11" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" 
                 Value="{Binding ShadowIntensity}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- 3. Lighting (Left, Row 2) -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,5,0">
                        <Grid>
                            <TextBlock Text="3D Lighting" FontSize="11" Foreground="Gray" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding LightingIntensity, StringFormat=P0}" FontSize="11" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" 
                 Value="{Binding LightingIntensity}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Empty Space (Right, Row 2) - or put another future control here -->
                </Grid>



            </StackPanel>

            <!-- RIGHT SIDE: PREVIEW (Compact) -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" VerticalAlignment="Top" Height="110">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Preview" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5" HorizontalAlignment="Center" Foreground="Gray"/>
                        <Image x:Name="PreviewImage" Width="100" Height="100" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock x:Name="PreviewText" Text="No image" FontSize="10" Margin="0,5,0,0" HorizontalAlignment="Center" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

       


    </Grid>
</UserControl>
